<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_VG_SEARCH_EB</name>
    <author>Vialma</author>
    <creationDate>May 4th, 2026</creationDate>
    <authorEmail>info@vialma.com</authorEmail>
    <copyright>(C) 2023 Vialma. All rights reserved.</copyright>
    <license>https://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
    <version>1.0.2</version>
    <description>MOD_VG_SEARCH_EB_XML_DESCRIPTION</description>
    <files>
        <filename module="mod_vg_search_eb">mod_vg_search_eb.php</filename>
        <filename>helper.php</filename>
        <folder>tmpl</folder>
        <folder>language</folder>
        <folder>src</folder>
        <folder>layouts</folder>
        <folder>media</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/en-GB.mod_vg_search_eb.ini</language>
        <language tag="en-GB">language/en-GB/en-GB.mod_vg_search_eb.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="orchestra_parent_id"
                    type="number"
                    label="MOD_VG_SEARCH_EB_ORCHESTRA_PARENT_ID"
                    description="MOD_VG_SEARCH_EB_ORCHESTRA_PARENT_ID_DESC"
                    default="0"
                    min="0"
                    step="1"
                />
                <field
                    name="orchestra_names"
                    type="list"
                    label="MOD_VG_SEARCH_EB_ORCHESTRA_NAMES"
                    description="MOD_VG_SEARCH_EB_ORCHESTRA_NAMES_DESC"
                    multiple="true"
                    layout="joomla.form.field.list-fancy-select"
                >
                    <option value="BBC Concert Orchestra">BBC Concert Orchestra</option>
                    <option value="BBC Singers">BBC Singers</option>
                    <option value="BBC Symphony Orchestra">BBC Symphony Orchestra</option>
                    <option value="London Philharmonic Orchestra">London Philharmonic Orchestra</option>
                    <option value="London Symphony Orchestra">London Symphony Orchestra</option>
                    <option value="Philharmonia">Philharmonia</option>
                    <option value="Royal Philharmonic Orchestra">Royal Philharmonic Orchestra</option>
                </field>
                <field
                    name="placeholder_orchestra"
                    type="text"
                    label="MOD_VG_SEARCH_EB_PLACEHOLDER_ORCHESTRA"
                    description="MOD_VG_SEARCH_EB_PLACEHOLDER_ORCHESTRA_DESC"
                    default="Select Orchestra"
                    filter="string"
                />
                <field
                    name="placeholder_genres"
                    type="text"
                    label="MOD_VG_SEARCH_EB_PLACEHOLDER_GENRES"
                    description="MOD_VG_SEARCH_EB_PLACEHOLDER_GENRES_DESC"
                    default="Type or Select Genres"
                    filter="string"
                />
                <field
                    name="placeholder_emotion"
                    type="text"
                    label="MOD_VG_SEARCH_EB_PLACEHOLDER_EMOTION"
                    description="MOD_VG_SEARCH_EB_PLACEHOLDER_EMOTION_DESC"
                    default="Type or Select Emotions"
                    filter="string"
                />
                <field
                    name="placeholder_venue"
                    type="text"
                    label="MOD_VG_SEARCH_EB_PLACEHOLDER_VENUE"
                    description="MOD_VG_SEARCH_EB_PLACEHOLDER_VENUE_DESC"
                    default="Select venues"
                    filter="string"
                />
                <field
                    name="show_venues"
                    type="radio"
                    label="MOD_VG_SEARCH_EB_SHOW_VENUES"
                    default="1"
                    class="btn-group btn-group-yesno"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field
                    name="module_layout"
                    type="list"
                    label="MOD_VG_SEARCH_EB_MODULE_LAYOUT"
                    description="MOD_VG_SEARCH_EB_MODULE_LAYOUT_DESC"
                    default="horizontal"
                    class="form-select"
                >
                    <option value="vertical">MOD_VG_SEARCH_EB_LAYOUT_VERTICAL</option>
                    <option value="horizontal">MOD_VG_SEARCH_EB_LAYOUT_HORIZONTAL</option>
                </field>
                <field
                    name="search_result_layout"
                    type="list"
                    label="MOD_VG_SEARCH_EB_SEARCH_RESULT_LAYOUT"
                    description="MOD_VG_SEARCH_EB_SEARCH_RESULT_LAYOUT_DESC"
                    default="timeline"
                    class="form-select"
                >
                    <option value="timeline">MOD_VG_SEARCH_EB_LAYOUT_TIMELINE</option>
                    <option value="column">MOD_VG_SEARCH_EB_LAYOUT_COLUMN</option>
                    <option value="columns">MOD_VG_SEARCH_EB_LAYOUT_COLUMNS</option>
                </field>
            </fieldset>
            <fieldset name="advanced">
                <field
                    name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    class="form-select"
                    validate="moduleLayout"
                />
                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    rows="3"
                    validate="CssIdentifier"
                />
                <field
                    name="item_id"
                    type="number"
                    label="MOD_VG_SEARCH_EB_ITEMID"
                    description="MOD_VG_SEARCH_EB_ITEMID_DESC"
                    default="0"
                    min="0"
                    step="1"
                />
            </fieldset>
        </fields>
    </config>
</extension>
