<?xml version="1.0" encoding="utf-8"?>
<extension version="4.2.0" type="plugin" group="eventbooking" method="upgrade">
    <name>PLG_EVENTBOOKING_GENRES_XML_NAME</name>
    <author>Vialma</author>
    <creationDate>May 6th, 2026</creationDate>
    <copyright>Copyright 2026</copyright>
    <license>https://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
    <authorEmail>info@vialma.com</authorEmail>
    <version>1.0.1</version>
    <description>PLG_EVENTBOOKING_GENRES_XML_DESCRIPTION</description>
    <files>
        <filename plugin="genres">genres.php</filename>
        <folder>tmpl</folder>
        <folder>override</folder>
    </files>
    <languages folder="language">
        <language tag="en-GB">en-GB/plg_eventbooking_genres.ini</language>
        <language tag="en-GB">en-GB/plg_eventbooking_genres.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="show_on_frontend"
                    type="radio"
                    label="PLG_EVENTBOOKING_GENRES_SHOW_ON_FRONTEND"
                    description="PLG_EVENTBOOKING_GENRES_SHOW_ON_FRONTEND_DESC"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                        name="genre_values"
                        type="textarea"
                        label="PLG_EVENTBOOKING_GENRES_VALUES_LABEL"
                        description="PLG_EVENTBOOKING_GENRES_VALUES_DESC"
                        rows="5"
                        cols="60"
                        filter="raw"
                        default="Solo Violin, Solo Piano, Chamber, Orchestral, Opera, Vocal, Contemporary-Classical, Cross-genre collaboration, Film Music, Folk, Jazz"
                />
            </fieldset>
        </fields>
    </config>
</extension>
